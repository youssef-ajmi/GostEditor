{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Gost Editor",
  "version": "0.1.0",
  "identifier": "com.gost.editor",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Gost Editor",
        "width": 1480,
        "height": 900,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "shell": {
      "scope": [
        {
          "name": "terminal-shell",
          "cmd": "cmd.exe",
          "args": true
        },
        {
          "name": "terminal-shell",
          "cmd": "powershell.exe",
          "args": true
        },
        {
          "name": "terminal-shell",
          "cmd": "bash",
          "args": true
        },
        {
          "name": "terminal-shell",
          "cmd": "zsh",
          "args": true
        },
        {
          "name": "terminal-shell",
          "cmd": "pwsh",
          "args": true
        }
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}